# Copy this file to .env and fill your keys. Do not commit real keys.

# Shared NVIDIA key (used by both embeddings and reasoning if specific keys are absent).
NVIDIA_API_KEY=

# Optional: separate keys per model (overrides NVIDIA_API_KEY for that model).
NVIDIA_EMBEDDING_API_KEY=
NVIDIA_REASONING_API_KEY=

# OpenWeatherMap key for weather-based hazard classification (optional).
OPENWEATHER_API_KEY=
